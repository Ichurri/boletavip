DATABASE_URL="postgresql://user:password@localhost:5432/boletavip"

# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Google OAuth (optional — the Google sign-in button only shows when both are set)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Vercel Blob (production only — without it, uploads go to /public/uploads on disk)
# BLOB_READ_WRITE_TOKEN=""

# Resend (emails: account verification + order notifications).
# Without the key, emails are logged to the console (fine for local dev).
# The resend.dev sandbox sender only delivers to your own Resend account email;
# use a verified domain in EMAIL_FROM to reach real buyers.
# RESEND_API_KEY=""
# EMAIL_FROM="Üticket <onboarding@resend.dev>"
