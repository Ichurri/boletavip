DATABASE_URL="postgresql://user:password@localhost:5432/boletavip"

# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Google OAuth (optional — the Google sign-in button only shows when both are set)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Vercel Blob (production only — without it, uploads go to /public/uploads on disk)
# BLOB_READ_WRITE_TOKEN=""

# Emails (account verification + order notifications).
# Provider selection: BREVO_API_KEY → Brevo; else RESEND_API_KEY → Resend;
# else emails are logged to the console (fine for local dev).
# Brevo (no own domain needed): EMAIL_FROM must be the sender verified in Brevo.
# BREVO_API_KEY=""
# Resend: needs a verified domain to deliver beyond your own account email.
# RESEND_API_KEY=""
# EMAIL_FROM="Üticket <tu-remitente-verificado@example.com>"
